{
  "name": "hotdog-instabot",
  "version": "1.0.0",
  "description": "Open-source ManyChat alternative — self-hosted Instagram DM automation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "nuke": "rm -rf node_modules && rm -rf bun.lock && rm -rf dist",
    "dev": "bun --watch src/index.ts",
    "build": "rimraf dist && tsc",
    "start": "bun dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "biome check --write ./",
    "lint": "biome lint --write",
    "import:csv": "bun src/scripts/import-csv.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "pino": "^9.6.0",
    "postgres": "^3.4.8",
    "resend": "^6.9.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.13.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
