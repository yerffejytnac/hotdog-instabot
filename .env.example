# Meta / Instagram API
META_APP_SECRET=your_meta_app_secret # You choose it
META_VERIFY_TOKEN=your_webhook_verify_token
INSTAGRAM_PAGE_ACCESS_TOKEN=your_page_access_token
INSTAGRAM_PAGE_ID=your_instagram_page_id

# Server
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Admin
ADMIN_API_KEY=your_admin_api_key # You choose it

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Email (optional — omit RESEND_API_KEY to disable email features)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=Your Brand <noreply@yourdomain.com>
WELCOME_EMAIL_TEMPLATE=bienvenido.html